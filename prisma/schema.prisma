generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String             @id
  name                 String
  email                String             @unique
  emailVerified        Boolean            @default(false)
  image                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  role                 String             @default("USER")
  banned               Boolean?           @default(false)
  banReason            String?
  banExpires           DateTime?
  bio                  String?
  date_of_birth        DateTime?
  gender               String?
  phone_number         String?
  accounts             Account[]
  channelMemberships   ChannelMember[]
  chats                Chat[]
  consultationChats    ConsultationChat[]
  consultationsAsPsych Consultation[]     @relation("PsychologistConsultations")
  consultationsAsUser  Consultation[]     @relation("UserConsultations")
  donations            Donation[]
  reports              Report[]
  schedules            Schedule[]
  sessions             Session[]

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Report {
  id           Int              @id @default(autoincrement()) @map("report_id")
  userId       String           @map("user_id")
  title        String           @db.VarChar(255)
  description  String
  status       ReportStatus     @default(PENDING)
  isAnonymous  Boolean          @default(false) @map("is_anonymous")
  isPublic     Boolean          @default(true) @map("is_public")
  address      String?          @db.VarChar(255)
  category     ReportCategory   @map("category")
  city         String           @db.VarChar(120)
  createdAt    DateTime         @default(now()) @map("created_at")
  district     String           @db.VarChar(120)
  incidentDate DateTime         @map("incident_date") @db.Date
  province     String           @db.VarChar(120)
  updatedAt    DateTime         @updatedAt @map("updated_at")
  donations    Donation[]
  evidences    ReportEvidence[]
  user         User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([incidentDate])
  @@index([isPublic, status])
  @@index([category])
  @@map("reports")
}

model ReportEvidence {
  id         Int      @id @default(autoincrement()) @map("evidence_id")
  reportId   Int      @map("report_id")
  fileName   String   @map("file_name") @db.VarChar(255)
  fileUrl    String   @map("file_url")
  mimeType   String   @map("mime_type") @db.VarChar(120)
  fileSize   Int      @map("file_size")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_evidences")
}

model Consultation {
  id             Int                @id @default(autoincrement()) @map("consult_id")
  userId         String             @map("user_id")
  psychologistId String?            @map("psychologist_id")
  title          String             @db.VarChar(255)
  category       String             @db.VarChar(255)
  description    String             @db.VarChar(255)
  date           DateTime           @db.Date
  time           DateTime           @db.Time(6)
  isAnonymous    Boolean            @default(false) @map("is_anonymous")
  attachmentUrl  String?            @map("attachment_url")
  status         ConsultationStatus
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  chats          ConsultationChat[]
  psychologist   User?              @relation("PsychologistConsultations", fields: [psychologistId], references: [id])
  user           User               @relation("UserConsultations", fields: [userId], references: [id])

  @@map("consultations")
}

model Donation {
  id              Int           @id @default(autoincrement()) @map("donation_id")
  userId          String        @map("user_id")
  reportId        Int?          @map("report_id")
  amount          Decimal       @db.Decimal(15, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  paymentStatus   PaymentStatus @map("payment_status")
  timestamp       DateTime      @default(now())
  midtransOrderId String?       @unique @map("midtrans_order_id")
  snapToken       String?       @map("snap_token")
  donationType    DonationType  @default(REPORT) @map("donation_type")
  report          Report?       @relation(fields: [reportId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([midtransOrderId])
  @@map("donations")
}

model Channel {
  id          Int             @id @default(autoincrement()) @map("channel_id")
  name        String          @unique @db.VarChar(100)
  description String?
  coverUrl    String?         @map("cover_url")
  type        ChannelType     @default(PUBLIC)
  createdAt   DateTime        @default(now()) @map("created_at")
  members     ChannelMember[]
  chats       Chat[]

  @@map("channels")
}

model ChannelMember {
  channelId Int         @map("channel_id")
  userId    String      @map("user_id")
  role      ChannelRole @default(MEMBER)
  joinedAt  DateTime    @default(now()) @map("joined_at")
  channel   Channel     @relation(fields: [channelId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@id([channelId, userId])
  @@map("channel_members")
}

model Chat {
  id          Int       @id @default(autoincrement()) @map("chat_id")
  channelId   Int       @map("channel_id")
  userId      String    @map("user_id")
  content     String
  mediaUrl    String?   @map("media_url")
  isAnonymous Boolean   @default(false) @map("is_anonymous")
  replyToId   Int?      @map("reply_to_id")
  timestamp   DateTime  @default(now())
  editedAt    DateTime? @map("edited_at")
  channel     Channel   @relation(fields: [channelId], references: [id])
  replyTo     Chat?     @relation("ChatReplies", fields: [replyToId], references: [id])
  replies     Chat[]    @relation("ChatReplies")
  user        User      @relation(fields: [userId], references: [id])

  @@map("chats")
}

model ConsultationChat {
  id             Int                @id @default(autoincrement()) @map("chat_id")
  consultationId Int                @map("consult_id")
  userId         String             @map("user_id")
  content        String
  mediaUrl       String?            @map("media_url")
  isAnonymous    Boolean            @default(false) @map("is_anonymous")
  replyToId      Int?               @map("reply_to_id")
  timestamp      DateTime           @default(now())
  consultation   Consultation       @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  replyTo        ConsultationChat?  @relation("ConsultationChatReplies", fields: [replyToId], references: [id])
  replies        ConsultationChat[] @relation("ConsultationChatReplies")
  user           User               @relation(fields: [userId], references: [id])

  @@map("consultation_chats")
}

model Schedule {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  dayOfWeek Int      @map("day_of_week")
  startTime DateTime @map("start_time") @db.Time(6)
  endTime   DateTime @map("end_time") @db.Time(6)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("schedules")
}

enum UserRole {
  USER
  PSYCHOLOGIST
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ReportCategory {
  PHYSICAL
  SEXUAL
  PSYCHOLOGICAL
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  REJECTED
}

enum ConsultationStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum DonationType {
  REPORT
  PLATFORM
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT_CARD
  EWALLET
  QRIS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
  CANCELLED
}

enum ChannelType {
  PUBLIC
  PRIVATE
}

enum ChannelRole {
  OWNER
  MODERATOR
  MEMBER
}
